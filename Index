  list.innerHTML = data.map(r => `
    <div class="admin-product-item">
      <div class="review-avatar" style="width:42px;height:42px;flex-shrink:0;">${r.name.charAt(0)}</div>
      <div class="admin-product-name">${r.name} — ${'★'.repeat(r.rating)}<br/><span style="font-size:12px;color:var(--gray);font-weight:400;">${r.text.substring(0,60)}...</span></div>
      <button class="admin-del-btn" onclick="deleteReview('${r.id}')"><i class="fas fa-trash"></i></button>
    </div>`).join('');
}

async function deleteReview(id) {
  if (!confirm('Delete this review?')) return;
  await sb.from('reviews').delete().eq('id', id);
  showToast('Review deleted', 'success');
  await loadReviews();
  loadAdminReviews();
}

// ── TOAST ─────────────────────────────────────────────────
function showToast(msg, type = 'success') {
  const wrap = document.getElementById('toastWrap');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.innerHTML = `<i class="fas fa-${type==='success'?'check-circle':'exclamation-circle'} ti"></i> ${msg}`;
  wrap.appendChild(toast);
  setTimeout(() => toast.remove(), 3500);
}

// Close admin on outside click
document.getElementById('adminModal').addEventListener('click', function(e) {
  if (e.target === this) closeAdmin();
});
</script>

