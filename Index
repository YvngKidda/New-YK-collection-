// Image preview + Cloudinary upload
function previewImage(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const prev = document.getElementById('uploadPreview');
    prev.src = e.target.result;
    prev.style.display = 'block';
  };
  reader.readAsDataURL(file);
}

async function uploadToCloudinary(file) {
  const fd = new FormData();
  fd.append('file', file);
  fd.append('upload_preset', CLOUDINARY_PRESET);
  const res = await fetch(`https://api.cloudinary.com/v1_1/${CLOUDINARY_CLOUD}/image/upload`, { method:'POST', body:fd });
  const data = await res.json();
  return data.secure_url;
}

async function addProduct() {
  const name = document.getElementById('pName').value.trim();
  const category = document.getElementById('pCat').value;
  const price = Number(document.getElementById('pPrice').value);
  const desc = document.getElementById('pDesc').value.trim();
  const avail = document.getElementById('pAvail').value === 'in';
  const fileInput = document.getElementById('imgUpload');

  if (!name || !category || !price) { showToast('Fill in all required fields', 'error'); return; }

  const btn = document.getElementById('addBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Uploading...';
  btn.disabled = true;

  let imageUrl = '';
  if (fileInput.files[0]) {
    try { imageUrl = await uploadToCloudinary(fileInput.files[0]); }
    catch(e) { showToast('Image upload failed', 'error'); btn.innerHTML = '<i class="fas fa-plus"></i> Add Product'; btn.disabled = false; return; }
  }

  const { error } = await sb.from('products').insert([{ name, category, price, description: desc, image_url: imageUrl, available: avail }]);
  if (error) { showToast('Failed to add product: ' + error.message, 'error'); }
  else {
    showToast(`"${name}" added successfully! 🎉`, 'success');
    document.getElementById('pName').value = '';
    document.getElementById('pCat').value = '';
    document.getElementById('pPrice').value = '';
    document.getElementById('pDesc').value = '';
    document.getElementById('uploadPreview').style.display = 'none';
    fileInput.value = '';
    await loadProducts();
    loadAdminProducts();
  }
  btn.innerHTML = '<i class="fas fa-plus"></i> Add Product';
  btn.disabled = false;
}

async function loadAdminProducts() {
  const { data } = await sb.from('products').select('*').order('created_at', { ascending: false });
  const list = document.getElementById('adminProductList');
  if (!data || !data.length) { list.innerHTML = '<p style="color:var(--gray);font-size:14px;">No products yet.</p>'; return; }
  list.innerHTML = data.map(p => `
    <div class="admin-product-item">
      <img class="admin-product-img" src="${p.image_url || 'https://via.placeholder.com/52'}" alt="${p.name}"/>
      <div class="admin-product-name">${p.name}<br/><span style="font-size:12px;color:var(--gray);font-weight:400;">${p.category}</span></div>
      <div class="admin-product-price">₦${Number(p.price).toLocaleString()}</div>
      <button class="admin-del-btn" onclick="deleteProduct('${p.id}','${p.name.replace(/'/g,"\\'")}')"><i class="fas fa-trash"></i></button>
    </div>`).join('');
}

async function deleteProduct(id, name) {
  if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;
  const { error } = await sb.from('products').delete().eq('id', id);
  if (error) { showToast('Delete failed', 'error'); return; }
  showToast(`"${name}" deleted`, 'success');
  await loadProducts();
  loadAdminProducts();
}

