}

// ── RENDER PRODUCTS ──────────────────────────────────────
function renderProducts(products) {
  const grid = document.getElementById('productsGrid');
  document.getElementById('productCount').textContent = products.length;
  if (!products.length) {
    grid.innerHTML = `<div class="empty-state"><i class="fas fa-box-open"></i><h3>No products found</h3><p>Try a different category or search term</p></div>`;
    return;
  }
